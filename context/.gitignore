# Framework development files
frameworks/*/Assets/Testing/
frameworks/*/Assets/[LEGACY]*/
frameworks/*/LensUnitTesting/
frameworks/*/Support/
frameworks/*/package-lock.json
frameworks/*/tsconfig.json
frameworks/SpectaclesSyncKit/CustomLandmarkGuidance/

# SpectaclesUIKit exclusions (examples, tests, resources)
frameworks/SpectaclesUIKit/Extras.lspkg/
frameworks/SpectaclesUIKit/TestScripts.lspkg/
frameworks/SpectaclesUIKit/UIKitResources/
frameworks/SpectaclesUIKit/ExampleScene.lspkg/

# Package and framework project files (keep only .lspkg source)
packages/*/*.scene
packages/*/*.esproj
frameworks/*/*.scene
frameworks/*/*.esproj
frameworks/*/*.json
packages/README.md
samples/README.md

# Docs website files
docs/**/*.tsx
docs/**/*.css
docs/**/*.scss
docs/**/_helpers/
docs/**/_helpers-*/

# GitHub workflows and CI configs
.github/
